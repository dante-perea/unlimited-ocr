# Copy to backend/.env and adjust as needed. All values are optional; the
# defaults below match the committed defaults in app/config.py.

APP_NAME=Unlimited-OCR Backend
ENVIRONMENT=development

# Comma-separated list of origins allowed by CORS (the frontend dev server).
CORS_ORIGINS=http://localhost:3000

# Compute-device override: cuda | mps | cpu. Leave blank to auto-detect.
DEVICE=

# Filesystem locations used by later tasks (PDF downloads, OCR output).
DATA_DIR=./data

# Directory where cached source PDFs live (NCBI task writes them here).
# Defaults to DATA_DIR/pdfs when blank.
PDF_CACHE_DIR=

# HuggingFace cache directory for model weights (downloaded on first OCR run).
HF_HOME=./.cache/huggingface

# ---- OCR pipeline ----
# MOCK / offline mode: 1 = return canned OCR output, no model/GPU needed.
# Lets the frontend be built/developed without a CUDA GPU.
OCR_MOCK=0

# HuggingFace model id (or local path) for Unlimited-OCR.
OCR_MODEL_NAME=baidu/Unlimited-OCR

# DPI for PDF→PNG rasterization (upstream example uses 300).
OCR_PDF_DPI=300

# Hard cap on pages processed per run (0 = no cap).
OCR_MAX_PAGES=0

# Facts extractor: "heuristic" (built-in) or a name registered via
# app.services.facts.register_fact_extractor.
FACTS_EXTRACTOR=heuristic
