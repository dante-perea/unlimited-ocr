# Copy to backend/.env and adjust as needed. All values are optional; the
# defaults below match the committed defaults in app/config.py.

APP_NAME=Unlimited-OCR Backend
ENVIRONMENT=development

# Comma-separated list of origins allowed by CORS (the frontend dev server).
CORS_ORIGINS=http://localhost:3000

# Compute-device override: cuda | mps | cpu. Leave blank to auto-detect.
DEVICE=

# Filesystem locations used by later tasks (PDF downloads, OCR output).
DATA_DIR=./data

# Directory where cached source PDFs live. Both /ncbi/fetch (downloads) and
# /ocr/run (reads) use this dir; leave blank to default to DATA_DIR/pdfs.
PDF_CACHE_DIR=

# HuggingFace cache directory for model weights (populated by the OCR task).
HF_HOME=./.cache/huggingface

# --- OCR pipeline -------------------------------------------------------------
# MOCK / offline mode: skip loading the real model and return canned OCR output.
# Lets the frontend be developed/demoed without a GPU. Set OCR_MOCK=1 to enable.
OCR_MOCK=0

# --- NCBI / PMC Open Access (search + PDF fetch) ------------------------------
# Optional NCBI API key. Raises the E-utility rate limit from 3 to 10 req/s.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
# Tool name + contact email sent with every E-utility request (NCBI policy).
NCBI_TOOL=unlimited-ocr-backend
NCBI_EMAIL=
# HTTP timeout (seconds) for upstream NCBI / PMC requests.
NCBI_REQUEST_TIMEOUT=30
